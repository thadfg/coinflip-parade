{
    auto_https off
    admin off
    debug
}

:8443 {
    tls /certs/dev.crt /certs/dev.key

    log {
        output file /var/log/caddy/access.log
        format json
        level INFO
    }

    # ============================
    # Jaeger Tracing UI
    # ============================
    @jaeger path /jaeger*
    handle @jaeger {        
        reverse_proxy jaeger:16686
    }

    # ============================
    # Unified Metrics (OTel Collector)
    # ============================
    # This replaces the broken 'ingestion/custom-metrics' logic.
    # It exposes the Collector's unified port (8889) to your browser/Prometheus.
    @metrics path /metrics*
    handle @metrics {
        reverse_proxy otel-collector:8889
    }

    # ============================
    # IngestionService
    # ============================
    @ingestion_api path /api/*
    @ingestion_health path /ingestion/health
    @ingestion_ready path /ingestion/ready
    @ingestion_live path /ingestion/live

    handle @ingestion_api {
        reverse_proxy ingestion:5283
    }
    handle @ingestion_health {
        reverse_proxy ingestion:5283
    }
    handle @ingestion_ready {
        reverse_proxy ingestion:5283
    }
    handle @ingestion_live {
        reverse_proxy ingestion:5283
    }

    # ============================
    # PersistenceService
    # ============================
    @persistence_health path /persistence/health
    @persistence_ready path /persistence/ready
    @persistence_live path /persistence/live

    handle @persistence_health {
        reverse_proxy persistenceservice:5067
    }
    handle @persistence_ready {
        reverse_proxy persistenceservice:5067
    }
    handle @persistence_live {
        reverse_proxy persistenceservice:5067
    }

    # ============================
    # Scalar UI + OpenAPI
    # ============================
    @scalar_assets path_regexp scalar_assets ^/scalar/(?:scalar\.js|scalar\.aspnetcore\.js)$
    @scalar_ui path /scalar/v1*
    @openapi_spec path /openapi/v1.json

    handle @scalar_assets {
        reverse_proxy ingestion:5283
    }
    handle @scalar_ui {
        reverse_proxy ingestion:5283
    }
    handle @openapi_spec {
        reverse_proxy ingestion:5283
    }

    # ============================
    # Default fallback
    # ============================
    handle {
        respond "Not Found" 404
    }
}