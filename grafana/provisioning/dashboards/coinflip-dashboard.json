{
  "id": null,
  "uid": "coinflip-observability",
  "title": "Coinflip Parade - Ingestion & Persistence",
  "tags": ["coinflip", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Ingestion - Total Comics Processed",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(ingestion_success_total{service=\"ingestion\"})"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Persistence - Total Comics Saved",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(saved_comics_total{service=\"persistence\"})"
        }
      ],
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Ingestion - Request Rate (per second)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(incoming_comics_total{service=\"ingestion\"}[1m])"
        }
      ],
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Persistence - Save Rate (per second)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(saved_comics_total{service=\"persistence\"}[1m])"
        }
      ],
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Ingestion - Batch Duration (ms)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ingestion_duration_seconds_bucket{service=\"ingestion\"}[5m])) by (le))"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Persistence - Save Duration (ms)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(save_duration_ms_bucket{service=\"persistence\"}[5m])) by (le))"
        }
      ],
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 6 }
    },
    {
      "type": "stat",
      "title": "Ingestion - Uptime",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{service=\"ingestion\"}"
        }
      ],
      "gridPos": { "x": 0, "y": 28, "w": 6, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Persistence - Uptime",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{service=\"persistence\"}"
        }
      ],
      "gridPos": { "x": 6, "y": 28, "w": 6, "h": 4 }
    }
  ]
}
