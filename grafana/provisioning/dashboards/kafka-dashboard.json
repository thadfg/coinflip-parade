{
  "id": null,
  "uid": "coinflip-kafka",
  "title": "Coinflip Parade - Kafka Consumer Dashboard",
  "tags": ["coinflip", "kafka", "ingestion"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Consumer Health",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{service=\"ingestion\"}"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "color": "red", "value": 0 },
          { "color": "green", "value": 1 }
        ]
      }
    },
    {
      "type": "stat",
      "title": "Total Lag (All Partitions)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kafka_consumer_lag{service=\"ingestion\"})"
        }
      ],
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Max Partition Lag",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "max(kafka_consumer_lag{service=\"ingestion\"})"
        }
      ],
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Lag Rate (Δ lag / sec)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(kafka_consumer_lag{service=\"ingestion\"}[1m])"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Lag Over Time",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kafka_consumer_lag{service=\"ingestion\"})"
        }
      ],
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Lag Rate Over Time",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(kafka_consumer_lag{service=\"ingestion\"}[1m])"
        }
      ],
      "gridPos": { "x": 0, "y": 10, "w": 16, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Messages Consumed per Second",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(kafka_messages_consumed_total{service=\"ingestion\"}[1m])"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 16, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Partition Lag Breakdown",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kafka_consumer_lag{service=\"ingestion\"}"
        }
      ],
      "gridPos": { "x": 0, "y": 22, "w": 16, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Commit Latency (95th percentile)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(kafka_commit_latency_ms_bucket{service=\"ingestion\"}[5m])) by (le))"
        }
      ],
      "gridPos": { "x": 0, "y": 28, "w": 16, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Offset Progression (Consumer vs Producer)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kafka_topic_highwater_mark - kafka_consumer_offset"
        }
      ],
      "gridPos": { "x": 0, "y": 34, "w": 16, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Messages Produced per Second",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(kafka_messages_produced_total{service=\"ingestion\"}[1m])"
        }
      ],
      "gridPos": { "x": 0, "y": 40, "w": 16, "h": 6 }
    }
  ]
}
