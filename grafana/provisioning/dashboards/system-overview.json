{
  "id": null,
  "uid": "coinflip-system-overview",
  "title": "Coinflip Parade - System Overview",
  "tags": ["coinflip", "overview", "system"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Pipeline Health",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "min(up{service=~\"ingestion|persistence\"})"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "color": "red", "value": 0 },
          { "color": "green", "value": 1 }
        ]
      }
    },
    
    {
      "type": "stat",
      "title": "Ingestion - Uptime",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "service_uptime_seconds"
        }
      ],
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
      "defaults": {
        "unit": "s",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null }
          ]
        }
      }
    }
    },
    {
      "type": "stat",
      "title": "Persistence - Uptime",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{service=\"persistence\"}"
        }
      ],
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    }
    ,
    {
      "type": "stat",
      "title": "Total Comics Ingested",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(ingestion_success_total) + sum(ingestion_failure_total)"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Total Comics Persisted",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(saved_comics_total{service=\"persistence\"})"
        }
      ],
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Ingestion Throughput (comics/sec)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(ingestion_success_total[1m])) + sum(rate(ingestion_failure_total[1m]))"
        }
      ],
      "gridPos": { "x": 0, "y": 4, "w": 10, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Persistence Throughput (comics/sec)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(saved_comics_total{service=\"persistence\"}[1m])"
        }
      ],
      "gridPos": { "x": 10, "y": 4, "w": 10, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "End-to-End Latency (Ingestion → Persistence)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(end_to_end_latency_ms_bucket[5m])) by (le))"
        }
      ],
      "gridPos": { "x": 0, "y": 10, "w": 20, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kafka_consumer_lag{group=\"ComicCsvIngestorGroup\"})",
          "legendFormat": "Unprocessed Comic Records"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 20, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Ingestion - Batch Duration (95th percentile)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ingestion_duration_seconds_bucket{service=\"ComicCsvIngestorService\"}[5m])) by (le)) * 1000"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": { "x": 0, "y": 22, "w": 10, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Persistence - Save Duration (95th percentile)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(save_duration_ms_bucket{service=\"persistence\"}[5m])) by (le))"
        }
      ],
      "gridPos": { "x": 10, "y": 22, "w": 10, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Error Rate (All Services)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(request_errors_total[5m]))"
        }
      ],
      "gridPos": { "x": 0, "y": 28, "w": 20, "h": 6 }
    }
  ]
}
