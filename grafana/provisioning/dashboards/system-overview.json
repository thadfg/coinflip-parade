{
  "id": null,
  "uid": "coinflip-system-overview",
  "title": "Coinflip Parade - System Overview",
  "tags": ["coinflip", "overview", "system"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 77,
  "refresh": "1s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "Pipeline Health",
      "datasource": "Prometheus",
      "targets": [{ "expr": "min(up{job=\"otel-collector-unified\"})", "instant": true }],
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Ingestion - Uptime",
      "datasource": "Prometheus",
      "targets": [{ 
        "expr": "max(process_uptime_seconds{service_name=\"ingestion\"})", 
        "instant": true 
      }],
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "dts", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "type": "stat",
      "title": "Persistence - Uptime",
      "datasource": "Prometheus",
      "targets": [{ 
        "expr": "max(process_uptime_seconds{service_name=\"PersistenceService\"})", 
        "instant": true 
      }],
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "dts", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "type": "stat",
      "title": "Total Comics Ingested",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(ingestion_success_total{service_name=\"ingestion\"}) or vector(0)", "instant": true }],
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 4 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }
      }
    },
    {
      "type": "stat",
      "title": "Total Comics Persisted",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(saved_comics_total{service_name=\"PersistenceService\"}) or vector(0)", "instant": true }],
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 4 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } }
      }
    },
    {
      "type": "timeseries",
      "title": "Ingestion Throughput (comics/sec)",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(ingestion_success_total{service_name=\"ingestion\"}[1m]))" }],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 7 }
    },
    {
      "type": "timeseries",
      "title": "Persistence Throughput (comics/sec)",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(saved_comics_total{service_name=\"PersistenceService\"}[1m]))" }],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 7 }
    },
    {
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "datasource": "Prometheus",
      "targets": [{ 
        "expr": "sum(kafka_consumer_lag{service=\"persistence\"})", 
        "legendFormat": "Unprocessed Records (Partition {{partition}})" 
      }],
      "gridPos": { "x": 0, "y": 15, "w": 16, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Network Connections",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(kestrel_active_connections) by (service_name)", "legendFormat": "{{service_name}}" }],
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "HTTP Check Durations",
      "datasource": "Prometheus",
      "targets": [{ "expr": "httpcheck_duration_milliseconds", "legendFormat": "{{http_url}}" }],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Ingestion - Batch Duration (95th %)",
      "datasource": "Prometheus",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(ingestion_duration_seconds_bucket{service_name=\"ingestion\"}[5m])) by (le)) * 1000" }],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "x": 0, "y": 27, "w": 12, "h": 7 }
    },
    {
      "type": "timeseries",
      "title": "Persistence - Save Duration (95th %)",
      "datasource": "Prometheus",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(save_duration_ms_bucket{service_name=\"PersistenceService\"}[5m])) by (le))" }],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "x": 12, "y": 27, "w": 12, "h": 7 }
    }
  ]
}